const Transaction = require('../models/Transaction');

/**
 * @desc    Mencatat transaksi kas baru (Debit/Kredit)
 * @route   POST /api/transactions
 * @access  Private (Hanya Bendahara, Wakil Bendahara, dan Ketua)
 */
const createTransaction = async (req, res) => {
  const { description, type, amount, section } = req.body;

  try {
    let receiptNumber = null;

    // Jika transaksi bertipe keluar (Kredit), buat nomor nota otomatis
    if (type === 'Keluar') {
      const timestamp = Date.now().toString().slice(-6);
      receiptNumber = `NOTA/OUT/${new Date().getFullYear()}/${timestamp}`;
    }

    const transaction = await Transaction.create({
      description,
      type,
      amount,
      section,
      receiptNumber,
      createdBy: req.user._id // Diambil dari token login via authMiddleware
    });

    res.status(201).json({
      success: true,
      message: 'Transaksi keuangan berhasil dicatat',
      data: transaction
    });
  } catch (error) {
    res.status(500).json({ message: 'Gagal mencatat transaksi', error: error.message });
  }
};

/**
 * @desc    Mengambil ringkasan saldo, total masuk, dan total keluar beserta list data
 * @route   GET /api/transactions
 * @access  Private (Bisa diakses seluruh Anggota terdaftar untuk transparansi)
 */
const getTransactions = async (req, res) => {
  try {
    // Ambil semua transaksi, populate data penginputnya
    const transactions = await Transaction.find({})
      .populate('createdBy', 'fullName role')
      .sort({ createdAt: -1 });

    // Hitung kalkulasi keuangan secara akumulatif
    let totalMasuk = 0;
    let totalKeluar = 0;

    transactions.forEach(t => {
      if (t.type === 'Masuk') totalMasuk += t.amount;
      if (t.type === 'Keluar') totalKeluar += t.amount;
    });

    const totalSaldo = totalMasuk - totalKeluar;

    res.json({
      summary: {
        totalSaldo,
        totalMasuk,
        totalKeluar
      },
      transactions
    });
  } catch (error) {
    res.status(500).json({ message: 'Gagal mengambil data laporan keuangan', error: error.message });
  }
};

