/**
 * @desc    Mengubah data transaksi kas (Edit)
 * @route   PUT /api/transactions/:id
 * @access  Private (Hanya Bendahara)
 */
const updateTransaction = async (req, res) => {
  const { description, type, amount, section } = req.body;

  try {
    const transaction = await Transaction.findById(req.params.id);

    if (!transaction) {
      return res.status(404).json({ message: 'Data transaksi tidak ditemukan' });
    }

    // Update field
    transaction.description = description || transaction.description;
    transaction.type = type || transaction.type;
    transaction.amount = amount || transaction.amount;
    transaction.section = section || transaction.section;

    const updatedTransaction = await transaction.save();

    res.json({
      success: true,
      message: 'Transaksi berhasil diperbarui',
      data: updatedTransaction
    });
  } catch (error) {
    res.status(500).json({ message: 'Gagal memperbarui transaksi', error: error.message });
  }
};

/**
 * @desc    Menghapus transaksi kas (Delete)
 * @route   DELETE /api/transactions/:id
 * @access  Private (Hanya Bendahara)
 */
const deleteTransaction = async (req, res) => {
  try {
    const transaction = await Transaction.findById(req.params.id);

    if (!transaction) {
      return res.status(404).json({ message: 'Data transaksi tidak ditemukan' });
    }

    // Gunakan deleteOne() menggantikan remove() yang sudah deprecated di Mongoose baru
    await transaction.deleteOne();

    res.json({ success: true, message: 'Transaksi berhasil dihapus' });
  } catch (error) {
    res.status(500).json({ message: 'Gagal menghapus transaksi', error: error.message });
  }
};

module.exports = { createTransaction, getTransactions, updateTransaction, deleteTransaction };